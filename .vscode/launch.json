{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django: F5 Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": ["runserver", "--noreload", "127.0.0.1:8000"],
            "django": true,
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env.local",
            "env": {
                "DJANGO_SETTINGS_MODULE": "config.settings"
            }
        }
    ]
}
