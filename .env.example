# Django
SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL container (DATABASE_URL is constructed in docker-compose.yml from these)
POSTGRES_DB=cperf
POSTGRES_USER=cperf
POSTGRES_PASSWORD=cperf

# Superuser (auto-created on startup if set)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com

# Application
APP_PORT=8000
